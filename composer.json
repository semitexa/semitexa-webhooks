{
  "name": "semitexa/webhooks",
  "description": "Semitexa Webhooks - inbound verification/deduplication and outbound durable delivery with retries",
  "type": "semitexa-module",
  "license": "MIT",
  "authors": [
    {
      "name": "Semitexa",
      "email": "support@semitexa.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "semitexa/core": "*",
    "semitexa/orm": "*"
  },
  "autoload": {
    "psr-4": {
      "Semitexa\\Webhooks\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Semitexa\\Webhooks\\Tests\\": "tests/"
    }
  },
  "extra": {
    "semitexa-module": {
      "extends": null
    }
  },
  "keywords": [
    "semitexa",
    "webhooks",
    "inbound",
    "outbound",
    "signature-verification"
  ]
}
